apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .Name }}
  annotations:
{{- range $key, $value := .Annotations }}
{{- if multiline $value }}
    {{ $key }}: |
{{ $value | indent 6 }}
{{- else }}
    {{ $key }}: {{ $value | quote }}
{{- end }}
{{- end }}
spec:
  ingressClassName: nginx
  rules:
  - host: {{ .Host }}
    http:
      paths:
      - path: {{ .Path }}
        pathType: {{ .PathType }}
        backend:
          service:
            name: snippet-test-backend
            port:
              number: 80
